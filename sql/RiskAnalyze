CREATE VIEW master_food_security AS
SELECT 
    g.country_name,
    g.year,
    g.gdp_per_capita,
    r.rainfall_mm,
    c.yield_per_hectare,
    fp.cereals_price_index,
    i.import_dependency_percent,
    cf.conflict_score
FROM gdp g
LEFT JOIN rainfall r 
    ON g.country_name = r.country_name 
    AND g.year = r.year
LEFT JOIN crop_yield c 
    ON g.country_name = c.country_name 
    AND g.year = c.year
LEFT JOIN food_prices fp 
    ON g.year = fp.year
LEFT JOIN import_dependency i 
    ON g.country_name = i.country_name 
    AND g.year = i.year
LEFT JOIN conflict cf 
    ON g.country_name = cf.country_name 
    AND g.year = cf.year
WHERE g.year BETWEEN 2010 AND 2022;

SELECT 
    COUNT(*) AS total_rows,
    COUNT(gdp_per_capita) AS has_gdp,
    COUNT(rainfall_mm) AS has_rainfall,
    COUNT(yield_per_hectare) AS has_yield,
    COUNT(cereals_price_index) AS has_prices,
    COUNT(import_dependency_percent) AS has_import,
    COUNT(conflict_score) AS has_conflict
FROM master_food_security;

