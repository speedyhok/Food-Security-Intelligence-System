CREATE TABLE gdp (
    id SERIAL PRIMARY KEY,
    country_name VARCHAR(100),
    year INT,
    gdp_per_capita NUMERIC(12,2)
);

CREATE TABLE rainfall (
    id SERIAL PRIMARY KEY,
    country_name VARCHAR(100),
    year INT,
    rainfall_mm NUMERIC(10,2)
);

CREATE TABLE crop_yield (
    id SERIAL PRIMARY KEY,
    country_name VARCHAR(100),
    year INT,
    yield_per_hectare NUMERIC(12,2)
);

CREATE TABLE food_prices (
    id SERIAL PRIMARY KEY,
    year INT,
    cereals_price_index NUMERIC(10,2)
);

CREATE TABLE import_dependency (
    id SERIAL PRIMARY KEY,
    country_name VARCHAR(100),
    year INT,
    import_dependency_percent NUMERIC(5,2)
);

CREATE TABLE conflict (
    id SERIAL PRIMARY KEY,
    country_name VARCHAR(100),
    year INT,
    total_events INT,
    total_fatalities INT,
    conflict_score NUMERIC(10,2)
);

CREATE TABLE risk_scores (
    id SERIAL PRIMARY KEY,
    country_name VARCHAR(100),
    year INT,
    final_score NUMERIC(10,2),
    risk_level VARCHAR(20)
);

